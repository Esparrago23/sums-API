# ============================================================
#  Configuración de la API SUMS
#  Copia este archivo a .env:   cp .env.example .env
#  (compose.yaml lee estos valores vía ${VAR:-default})
# ============================================================

# --- Puertos ---
# Puerto local de la API al correrla sin Docker (en Docker, compose fija PORT=3003).
API_PORT=3000
# PostgreSQL expuesto en el host (host:5433 -> contenedor:5432).
DB_EXTERNAL_PORT=5433
# Balanceador nginx = ÚNICO punto de entrada público (host:81 -> contenedor:80).
NGINX_PORT=81

# --- Base de datos ---
DB_USER=postgres
DB_PASS=postgres
DB_TEMPLATE=sums_template

# --- Seguridad ---
# Secreto para firmar los JWT.
JWT_SECRET=sums_jwt_secret_2026

# Clave maestra del CIFRADO DE DATOS SENSIBLES en reposo (nombres de persona y dirección).
#   - OBLIGATORIA en producción. Si no se define, la API arranca igual pero usa una
#     clave de desarrollo insegura y avisa por consola.
#   - Debe ser una cadena larga y aleatoria. Genera una con cualquiera de estos:
#       openssl rand -base64 48
#       node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#   - NO la subas al repositorio (.env está en .gitignore).
#   - ADVERTENCIA: si cambias esta clave DESPUÉS de cifrar datos, esos datos ya NO se
#     podrán descifrar. Guárdala en un lugar seguro.
ENCRYPTION_MASTER_KEY=REEMPLAZA-con-una-clave-larga-y-aleatoria

# --- CORS (orígenes permitidos del front; vacío = se permiten todos) ---
ORIGIN_URL_1=
ORIGIN_URL_2=

# --- Réplica de BD (opcional; dejar vacío si no se usa) ---
DB_HOST_DB=
DB_PORT_DB=
DB_USER_DB=
DB_PASSWORD_DB=
DB_TEMPLATE_DB=
DB_SSLMODE_DB=disable
